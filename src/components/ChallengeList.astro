---
import type { Post } from '@/lib/posts';
import { listYearFor, postUrl, reviewSlugsForChallengeItem } from '@/lib/posts';

interface Props {
  post: Post;
  posts: Post[];
}

const { post, posts } = Astro.props;
const items = post.data.challengeItems ?? [];
const bySlug = new Map(posts.map((entry) => [entry.data.slug, entry]));
const listYear = listYearFor(post) ?? post.data.pubDate.getUTCFullYear();

function normalize(value = '') {
  return value.toLowerCase().replace(/[^a-z0-9]+/g, ' ').trim();
}

function reviewFor(item: (typeof items)[number]) {
  const reviewSlug = reviewSlugsForChallengeItem(item)[0];
  if (reviewSlug) return bySlug.get(reviewSlug);
  const title = normalize(item.bookTitle);
  if (!title) return undefined;
  return posts.find((entry) => normalize(entry.data.bookTitle).includes(title));
}

function reviewsFor(item: (typeof items)[number]) {
  const explicitReviews = reviewSlugsForChallengeItem(item)
    .map((slug) => bySlug.get(slug))
    .filter((entry): entry is Post => Boolean(entry));

  if (explicitReviews.length > 0) return explicitReviews;

  const fallbackReview = reviewFor(item);
  return fallbackReview ? [fallbackReview] : [];
}

const completed = items.filter((item) => item.done).length;
---

<section class="challenge-list" aria-labelledby="challenge-list-heading">
  <div class="challenge-summary">
    <div>
      <p class="eyebrow">Reading challenge</p>
      <h2 id="challenge-list-heading">{listYear} master list</h2>
    </div>
    <p><strong>{completed}</strong> of <strong>{items.length}</strong> complete</p>
  </div>

  <div class="challenge-table-wrap">
    <table class="challenge-table">
      <thead>
        <tr>
          <th scope="col">Status</th>
          <th scope="col">Month</th>
          <th scope="col">Cover</th>
          <th scope="col">Challenge</th>
          <th scope="col">Selection</th>
          <th scope="col">Review</th>
        </tr>
      </thead>
      <tbody>
        {
          items.map((item) => {
            const reviews = reviewsFor(item);
            const review = reviews[0];
            const cover = review?.data.cover;
            const reviewSelections = reviews.map((entry) => entry.data.bookTitle).filter(Boolean);
            const reviewAuthors = [...new Set(reviews.map((entry) => entry.data.bookAuthor).filter(Boolean))];
            const selection =
              item.bookTitle ??
              (reviewSelections.length > 1 ? reviewSelections.join('; ') : review?.data.bookTitle) ??
              item.selection ??
              'TBC';
            const bookAuthor =
              item.bookAuthor ??
              (reviewAuthors.length > 1 ? reviewAuthors.join('; ') : review?.data.bookAuthor);

            return (
              <tr class={item.done ? 'is-complete' : 'is-planned'}>
                <td data-label="Status">
                  <span class="status-pill">
                    <span class="status-box" aria-hidden="true"></span>
                    {item.done ? 'Done' : 'Planned'}
                  </span>
                </td>
                <th scope="row" data-label="Month">{item.month}</th>
                <td data-label="Cover">
                  {
                    cover ? (
                      <img class="challenge-cover" src={cover} alt="" loading="lazy" decoding="async" />
                    ) : (
                      <span class="challenge-cover-placeholder" aria-hidden="true">
                        {item.month.slice(0, 3)}
                      </span>
                    )
                  }
                </td>
                <td data-label="Challenge">
                  <span class="challenge-prompt">{item.prompt}</span>
                </td>
                <td data-label="Selection">
                  <span class="challenge-selection">{selection}</span>
                  {bookAuthor && <small>by {bookAuthor}</small>}
                </td>
                <td data-label="Review">
                  {
                    reviews.length > 0 ? (
                      <div class="challenge-review-links">
                        {reviews.map((entry, index) => (
                          <a class="review-link" href={postUrl(entry)}>
                            {reviews.length > 1 ? `Read ${index + 1}` : 'Read'}
                          </a>
                        ))}
                      </div>
                    ) : (
                      <span class="review-pending">Not posted</span>
                    )
                  }
                </td>
              </tr>
            );
          })
        }
      </tbody>
    </table>
  </div>
</section>
