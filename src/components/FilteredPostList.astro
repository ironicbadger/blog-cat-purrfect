---
import type { Post } from '@/lib/posts';
import { categoryDefinitions, slugifyTag, uniqueValues } from '@/lib/posts';
import PostCard from './PostCard.astro';

interface Props {
  posts: Post[];
}

const { posts } = Astro.props;
const years = [...new Set(posts.map((post) => post.data.pubDate.getUTCFullYear()))].sort((a, b) => b - a);
const authors = uniqueValues(posts, (post) => post.data.author);
const bookAuthors = uniqueValues(posts, (post) => post.data.bookAuthor);
const formats = uniqueValues(posts, (post) => post.data.format);
const outcomes = uniqueValues(posts, (post) => post.data.outcome);
const tags = uniqueValues(posts, (post) => post.data.tags);
const genres = uniqueValues(posts, (post) => post.data.genres);
const categoryLabels = Object.fromEntries(categoryDefinitions.map((category) => [category.id, category.label]));
---

<section class="review-browser" data-review-browser>
  <div class="filter-panel" aria-label="Review filters">
    <label class="search-field">
      <span>Search reviews</span>
      <input data-filter="q" type="search" placeholder="Title, author, tag, review text..." autocomplete="off" />
      <input data-filter="category" type="hidden" value="" />
    </label>

    <div class="active-filter-summary" data-active-category hidden>
      <span>Active shelf</span>
      <strong data-active-category-label></strong>
      <button type="button" data-clear-category aria-label="Clear shelf filter">x</button>
    </div>

    <div class="filter-grid">
      <label>
        <span>Year</span>
        <select data-filter="year">
          <option value="">All years</option>
          {years.map((year) => <option value={year}>{year}</option>)}
        </select>
      </label>
      <label>
        <span>Format</span>
        <select data-filter="format">
          <option value="">All formats</option>
          {formats.map((item) => <option value={item.name}>{item.name} ({item.count})</option>)}
        </select>
      </label>
      <label>
        <span>Book author</span>
        <select data-filter="bookAuthor">
          <option value="">All authors</option>
          {bookAuthors.map((item) => <option value={item.name}>{item.name} ({item.count})</option>)}
        </select>
      </label>
      <label>
        <span>Reviewer</span>
        <select data-filter="author">
          <option value="">All reviewers</option>
          {authors.map((item) => <option value={item.name}>{item.name} ({item.count})</option>)}
        </select>
      </label>
      <label>
        <span>Genre / subject</span>
        <select data-filter="genre">
          <option value="">All genres</option>
          {genres.map((item) => <option value={slugifyTag(item.name)}>{item.name} ({item.count})</option>)}
        </select>
      </label>
      <label>
        <span>Tag</span>
        <select data-filter="tag">
          <option value="">All tags</option>
          {tags.map((item) => <option value={slugifyTag(item.name)}>{item.name} ({item.count})</option>)}
        </select>
      </label>
      <label>
        <span>Outcome</span>
        <select data-filter="outcome">
          <option value="">All outcomes</option>
          {outcomes.map((item) => <option value={item.name}>{item.name} ({item.count})</option>)}
        </select>
      </label>
    </div>

    <div class="filter-actions">
      <p><strong data-count>{posts.length}</strong> reviews</p>
      <button type="button" data-reset>Reset all</button>
    </div>
  </div>

  <script is:inline type="application/json" data-category-labels set:html={JSON.stringify(categoryLabels)} />

  <div class="post-list" data-post-list>
    {posts.map((post) => <PostCard post={post} />)}
  </div>

  <p class="empty-state" data-empty hidden>No reviews match those filters.</p>
</section>

<script>
  const browser = document.querySelector<HTMLElement>('[data-review-browser]');

  if (browser) {
    const cards = [...browser.querySelectorAll<HTMLElement>('[data-post-card]')];
    const count = browser.querySelector<HTMLElement>('[data-count]');
    const empty = browser.querySelector<HTMLElement>('[data-empty]');
    const controls = [...browser.querySelectorAll<HTMLInputElement | HTMLSelectElement>('[data-filter]')];
    const reset = browser.querySelector<HTMLButtonElement>('[data-reset]');
    const categoryControl = browser.querySelector<HTMLInputElement>('[data-filter="category"]');
    const activeCategory = browser.querySelector<HTMLElement>('[data-active-category]');
    const activeCategoryLabel = browser.querySelector<HTMLElement>('[data-active-category-label]');
    const clearCategory = browser.querySelector<HTMLButtonElement>('[data-clear-category]');
    const categoryData = browser.querySelector<HTMLScriptElement>('[data-category-labels]');
    const categoryLabels = categoryData?.textContent ? JSON.parse(categoryData.textContent) : {};

    const normalize = (value: string) => value.toLowerCase().trim();

    function removeUrlParam(name: string) {
      const params = new URLSearchParams(location.search);
      params.delete(name);
      const query = params.toString();
      history.replaceState(null, '', query ? `${location.pathname}?${query}` : location.pathname);
    }

    function applyFilters() {
      const values: Record<string, string> = {};
      for (const control of controls) {
        values[control.dataset.filter ?? ''] = normalize(control.value);
      }

      let visible = 0;

      for (const card of cards) {
        const search = card.dataset.search ?? '';
        const tags = (card.dataset.tags ?? '').split('|');
        const genres = (card.dataset.genres ?? '').split('|');
        const categories = (card.dataset.categories ?? '').split('|');
        const haystackMatch = !values.q || search.includes(values.q);
        const yearMatch = !values.year || card.dataset.year === values.year;
        const authorMatch = !values.author || normalize(card.dataset.author ?? '') === values.author;
        const bookAuthorMatch = !values.bookAuthor || normalize(card.dataset.bookAuthor ?? '') === values.bookAuthor;
        const formatMatch = !values.format || normalize(card.dataset.format ?? '') === values.format;
        const outcomeMatch = !values.outcome || normalize(card.dataset.outcome ?? '') === values.outcome;
        const tagMatch = !values.tag || tags.includes(values.tag);
        const genreMatch = !values.genre || genres.includes(values.genre);
        const categoryMatch = !values.category || categories.includes(values.category);
        const isVisible =
          haystackMatch &&
          yearMatch &&
          authorMatch &&
          bookAuthorMatch &&
          formatMatch &&
          outcomeMatch &&
          tagMatch &&
          genreMatch &&
          categoryMatch;

        card.toggleAttribute('hidden', !isVisible);
        if (isVisible) visible += 1;
      }

      if (count) count.textContent = String(visible);
      if (empty) empty.hidden = visible !== 0;
      if (activeCategory && activeCategoryLabel) {
        const label = values.category ? (categoryLabels[values.category] ?? values.category) : '';
        activeCategory.hidden = !label;
        activeCategoryLabel.textContent = label;
      }

      window.dispatchEvent(
        new CustomEvent('review-filters-changed', {
          detail: { category: values.category },
        })
      );
    }

    controls.forEach((control) => control.addEventListener('input', applyFilters));
    clearCategory?.addEventListener('click', () => {
      if (categoryControl) categoryControl.value = '';
      removeUrlParam('category');
      applyFilters();
    });
    reset?.addEventListener('click', () => {
      controls.forEach((control) => {
        control.value = '';
      });
      history.replaceState(null, '', location.pathname);
      applyFilters();
    });

    const params = new URLSearchParams(location.search);
    for (const control of controls) {
      const value = params.get(control.dataset.filter ?? '');
      if (value !== null) control.value = value;
    }
    applyFilters();
  }
</script>
