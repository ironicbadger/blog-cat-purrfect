---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getShelfGroups, isBrowsablePost, postUrl, shelfDateLabel, sortPosts } from '@/lib/posts';

const posts = sortPosts((await getCollection('posts')).filter(isBrowsablePost));
const groups = getShelfGroups(posts);
---

<BaseLayout title="Bookshelf" description="A visual, chronological shelf of every PurrfectProse review.">
  <section class="page-heading bookshelf-heading">
    <h1>Bookshelf</h1>
    <p>A cover-led archive of every review, newest first.</p>
    <p class="bookshelf-count">
      <strong>{posts.length}</strong> review total
    </p>
  </section>

  <div class="bookshelf-list">
    {
      groups.map((group) => (
        <section class="bookshelf-year" aria-labelledby={`bookshelf-${group.id}`}>
          <div class="bookshelf-year-label">
            <h2 id={`bookshelf-${group.id}`}>{group.label}</h2>
            <span>{group.posts.length} {group.posts.length === 1 ? 'review' : 'reviews'}</span>
          </div>
          <div class="bookshelf-grid">
            {group.posts.map((post) => {
              const title = post.data.bookTitle ?? post.data.title;
              const context = post.data.bookTitle ? post.data.title : undefined;
              const initial = title.trim().charAt(0) || 'P';

              return (
                <article class="bookshelf-card">
                  <a href={postUrl(post)} aria-label={`Read ${title}`}>
                    <div class="bookshelf-cover-frame">
                      {
                        post.data.cover ? (
                          <img src={post.data.cover} alt="" loading="lazy" />
                        ) : (
                          <span class="bookshelf-cover-placeholder" aria-hidden="true">{initial}</span>
                        )
                      }
                    </div>
                    <div class="bookshelf-card-copy">
                      <time datetime={post.data.pubDate.toISOString()}>{shelfDateLabel(post)}</time>
                      <h3>{title}</h3>
                      {post.data.bookAuthor && <p class="book-line">by {post.data.bookAuthor}</p>}
                      {context && <p>{context}</p>}
                      <div class="bookshelf-meta">
                        {post.data.format && <span>{post.data.format}</span>}
                        {post.data.publicationYear && <span>Published {post.data.publicationYear}</span>}
                      </div>
                    </div>
                  </a>
                </article>
              );
            })}
          </div>
        </section>
      ))
    }
  </div>
</BaseLayout>
