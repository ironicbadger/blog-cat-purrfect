---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import {
  categoryDefinitions,
  excerptFor,
  formatDate,
  isBrowsablePost,
  postCategories,
  postUrl,
  readingWithEllaNumber,
  slugifyTag,
  sortPosts,
} from '@/lib/posts';

type GraphKind = 'post' | 'list' | 'tag' | 'author' | 'year' | 'format' | 'category';

type GraphNode = {
  id: string;
  label: string;
  kind: GraphKind;
  href?: string;
  meta?: string;
  description?: string;
  search: string;
  radius?: number;
  featured?: boolean;
};

type GraphLink = {
  source: string;
  target: string;
  kind: string;
};

const posts = sortPosts((await getCollection('posts')).filter(isBrowsablePost));
const nodes = new Map<string, GraphNode>();
const links: GraphLink[] = [];
const seenLinks = new Set<string>();

function addNode(node: GraphNode) {
  if (!nodes.has(node.id)) nodes.set(node.id, node);
}

function addLink(source: string, target: string, kind: string) {
  if (source === target) return;
  const key = [source, target].sort().join('::');
  if (seenLinks.has(key)) return;
  seenLinks.add(key);
  links.push({ source, target, kind });
}

function addFacet(kind: Exclude<GraphKind, 'post' | 'list'>, label: string, href?: string) {
  const clean = label.trim();
  if (!clean) return undefined;
  const id = `${kind}:${slugifyTag(clean)}`;
  addNode({
    id,
    label: clean,
    kind,
    href,
    search: `${kind} ${clean}`.toLowerCase(),
  });
  return id;
}

for (const category of categoryDefinitions) {
  addNode({
    id: `category:${category.id}`,
    label: category.label,
    kind: 'category',
    href: category.href,
    meta: 'Shelf',
    search: `shelf category ${category.label}`.toLowerCase(),
  });
}

for (const post of posts) {
  const kind: GraphKind = 'post';
  const postId = `post:${post.data.slug}`;
  const postMeta = [
    formatDate(post.data.pubDate),
    post.data.format,
    post.data.bookAuthor,
  ].filter(Boolean).join(' | ');
  const search = [
    post.data.title,
    post.data.bookTitle,
    post.data.bookAuthor,
    post.data.format,
    post.data.tags.join(' '),
    post.data.genres.join(' '),
  ].filter(Boolean).join(' ').toLowerCase();

  addNode({
    id: postId,
    label: post.data.bookTitle ?? post.data.title,
    kind,
    href: postUrl(post),
    meta: postMeta,
    description: excerptFor(post, 190),
    search,
    featured: post === posts[0],
  });

  const yearId = addFacet('year', String(post.data.pubDate.getUTCFullYear()));
  if (yearId) addLink(postId, yearId, 'read-year');

  const formatId = post.data.format ? addFacet('format', post.data.format) : undefined;
  if (formatId) addLink(postId, formatId, 'format');

  const authorId = post.data.bookAuthor ? addFacet('author', post.data.bookAuthor) : undefined;
  if (authorId) addLink(postId, authorId, 'book-author');

  for (const category of postCategories(post)) {
    addLink(postId, `category:${category}`, 'shelf');
  }

  for (const tag of post.data.tags) {
    const tagId = addFacet('tag', tag, `/tag/${slugifyTag(tag)}/`);
    if (tagId) addLink(postId, tagId, 'tag');
  }

  for (const genre of post.data.genres) {
    const genreId = addFacet('tag', genre, `/tag/${slugifyTag(genre)}/`);
    if (genreId) addLink(postId, genreId, 'subject');
  }

  const ellaNumber = readingWithEllaNumber(post);
  if (ellaNumber !== undefined) {
    const sequenceId = addFacet('tag', `Ella book ${ellaNumber}`);
    if (sequenceId) addLink(postId, sequenceId, 'sequence');
  }
}

const degree = new Map<string, number>();
for (const link of links) {
  degree.set(link.source, (degree.get(link.source) ?? 0) + 1);
  degree.set(link.target, (degree.get(link.target) ?? 0) + 1);
}

const graphData = {
  featuredId: posts[0] ? `post:${posts[0].data.slug}` : undefined,
  nodes: [...nodes.values()].map((node) => ({
    ...node,
    degree: degree.get(node.id) ?? 0,
    radius:
      node.featured ? 13 :
      node.kind === 'category' ? 11 :
      node.kind === 'list' ? 9 :
      node.kind === 'post' ? 6 :
      Math.min(9, 4 + Math.sqrt(degree.get(node.id) ?? 1)),
  })),
  links,
};
---

<BaseLayout title="Grid" description="A visual map of PurrfectProse reviews, tags, authors, and reading years.">
  <section class="grid-page" data-knowledge-grid>
    <div class="grid-heading">
      <p class="eyebrow">Reading map</p>
      <h1>Grid</h1>
    </div>

    <section class="knowledge-grid" aria-label="Review relationship grid">
      <div class="grid-toolbar">
        <label class="grid-search">
          <span>Find</span>
          <input type="search" placeholder="Atwood, audiobooks, Ella..." data-grid-search autocomplete="off" />
        </label>
        <div class="grid-modes" aria-label="Graph scope">
          <button type="button" data-grid-mode="all" aria-pressed="true">All</button>
          <button type="button" data-grid-mode="reading-with-ella">Ella</button>
          <button type="button" data-grid-mode="monthly-challenge">Challenge</button>
          <button type="button" data-grid-mode="audiobooks">Audio</button>
        </div>
      </div>

      <div class="grid-stage">
        <canvas data-grid-canvas></canvas>
        <div class="grid-tooltip" data-grid-tooltip hidden></div>
      </div>

      <aside class="grid-inspector" data-grid-inspector aria-live="polite">
        <p class="eyebrow" data-grid-kind>Selected</p>
        <h2 data-grid-title>Choose a review</h2>
        <p data-grid-meta></p>
        <p data-grid-description></p>
        <a class="review-link" href="#" data-grid-link hidden>Open</a>
      </aside>
    </section>

    <script is:inline type="application/json" data-grid-data set:html={JSON.stringify(graphData)} />
  </section>
</BaseLayout>

<script>
  const root = document.querySelector<HTMLElement>('[data-knowledge-grid]');

  if (root) {
    const canvas = root.querySelector<HTMLCanvasElement>('[data-grid-canvas]');
    const dataNode = root.querySelector<HTMLScriptElement>('[data-grid-data]');
    const search = root.querySelector<HTMLInputElement>('[data-grid-search]');
    const buttons = [...root.querySelectorAll<HTMLButtonElement>('[data-grid-mode]')];
    const tooltip = root.querySelector<HTMLElement>('[data-grid-tooltip]');
    const inspector = root.querySelector<HTMLElement>('[data-grid-inspector]');
    const kindEl = inspector?.querySelector<HTMLElement>('[data-grid-kind]');
    const titleEl = inspector?.querySelector<HTMLElement>('[data-grid-title]');
    const metaEl = inspector?.querySelector<HTMLElement>('[data-grid-meta]');
    const descriptionEl = inspector?.querySelector<HTMLElement>('[data-grid-description]');
    const linkEl = inspector?.querySelector<HTMLAnchorElement>('[data-grid-link]');

    if (canvas && dataNode) {
      const graphCanvas = canvas;
      const graph = JSON.parse(dataNode.textContent ?? '{"nodes":[],"links":[]}');
      const ctx = graphCanvas.getContext('2d');
      const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const colors: Record<string, string> = {
        post: '#28666e',
        list: '#d94747',
        tag: '#d7a845',
        author: '#8158a5',
        year: '#5c7f68',
        format: '#3d6fb6',
        category: '#1f2445',
      };
      const cluster: Record<string, { x: number; y: number }> = {
        category: { x: 0.5, y: 0.18 },
        list: { x: 0.5, y: 0.36 },
        post: { x: 0.5, y: 0.55 },
        tag: { x: 0.22, y: 0.62 },
        author: { x: 0.78, y: 0.62 },
        year: { x: 0.5, y: 0.82 },
        format: { x: 0.5, y: 0.72 },
      };
      const categoryModes: Record<string, string> = {
        'reading-with-ella': 'category:reading-with-ella',
        'monthly-challenge': 'category:monthly-challenge',
        audiobooks: 'category:audiobooks',
      };

      let mode = 'all';
      let query = '';
      let alpha = 1;
      let hovered: any = null;
      let selected: any = null;
      let width = 0;
      let height = 0;
      let activeNodeIds = new Set<string>();
      let activeLinks: any[] = [];

      const nodes = graph.nodes.map((node: any, index: number) => {
        const angle = index * 2.399963229728653;
        const ring = 18 + (index % 19) * 4;
        return {
          ...node,
          seedAngle: angle,
          seedRing: ring,
          positioned: false,
          x: 0,
          y: 0,
          vx: 0,
          vy: 0,
        };
      });
      const byId = new Map(nodes.map((node: any) => [node.id, node]));
      const links = graph.links
        .map((link: any) => ({ ...link, sourceNode: byId.get(link.source), targetNode: byId.get(link.target) }))
        .filter((link: any) => link.sourceNode && link.targetNode);
      selected = byId.get(graph.featuredId) ?? nodes[0];

      function neighbors(seedIds: Set<string>, depth = 1) {
        const result = new Set(seedIds);
        let frontier = new Set(seedIds);
        for (let step = 0; step < depth; step += 1) {
          const next = new Set<string>();
          for (const link of links) {
            if (frontier.has(link.source) || frontier.has(link.target)) {
              if (!result.has(link.source)) next.add(link.source);
              if (!result.has(link.target)) next.add(link.target);
            }
          }
          if (next.size === 0) break;
          next.forEach((id) => result.add(id));
          frontier = next;
        }
        return result;
      }

      function setActiveGraph() {
        let seed = new Set<string>();

        if (mode === 'all') {
          activeNodeIds = new Set(nodes.map((node: any) => node.id));
        } else {
          const categoryId = categoryModes[mode];
          if (categoryId) seed.add(categoryId);
          activeNodeIds = neighbors(seed, 2);
        }

        if (query) {
          seed = new Set(nodes.filter((node: any) => node.search.includes(query)).map((node: any) => node.id));
          activeNodeIds = neighbors(seed, 1);
        }

        activeLinks = links.filter((link: any) => activeNodeIds.has(link.source) && activeNodeIds.has(link.target));
        if (selected && !activeNodeIds.has(selected.id)) {
          selected = nodes.find((node: any) => activeNodeIds.has(node.id)) ?? nodes[0];
          updateInspector(selected);
        }
        alpha = 1;
      }

      function resize() {
        const rect = graphCanvas.getBoundingClientRect();
        const ratio = window.devicePixelRatio || 1;
        width = Math.max(320, rect.width);
        height = Math.max(320, rect.height);
        graphCanvas.width = Math.floor(width * ratio);
        graphCanvas.height = Math.floor(height * ratio);
        ctx?.setTransform(ratio, 0, 0, ratio, 0, 0);
        nodes.forEach((node: any) => {
          if (!node.positioned || !Number.isFinite(node.x) || !Number.isFinite(node.y)) {
            const home = cluster[node.kind] ?? cluster.post;
            const spread = Math.min(width, height) * 0.14;
            node.x = width * home.x + Math.cos(node.seedAngle) * (node.seedRing + spread * 0.2);
            node.y = height * home.y + Math.sin(node.seedAngle) * (node.seedRing + spread * 0.2);
            node.positioned = true;
          }
        });
        alpha = 1;
      }

      function updateInspector(node: any) {
        if (!node) return;
        if (kindEl) kindEl.textContent = node.kind;
        if (titleEl) titleEl.textContent = node.label;
        if (metaEl) {
          metaEl.textContent = node.meta || `${node.degree} links`;
          metaEl.hidden = !metaEl.textContent;
        }
        if (descriptionEl) {
          descriptionEl.textContent = node.description || '';
          descriptionEl.hidden = !descriptionEl.textContent;
        }
        if (linkEl) {
          linkEl.href = node.href || '#';
          linkEl.hidden = !node.href;
        }
      }

      function tick() {
        if (alpha < 0.015 && reduceMotion) return;

        for (const link of activeLinks) {
          const source = link.sourceNode;
          const target = link.targetNode;
          const dx = target.x - source.x;
          const dy = target.y - source.y;
          const distance = Math.max(1, Math.hypot(dx, dy));
          const targetDistance = source.kind === 'post' || target.kind === 'post' ? 76 : 98;
          const force = (distance - targetDistance) * 0.0018 * alpha;
          const fx = (dx / distance) * force;
          const fy = (dy / distance) * force;
          source.vx += fx;
          source.vy += fy;
          target.vx -= fx;
          target.vy -= fy;
        }

        const activeNodes = nodes.filter((node: any) => activeNodeIds.has(node.id));

        for (let i = 0; i < activeNodes.length; i += 1) {
          const a = activeNodes[i];
          for (let j = i + 1; j < activeNodes.length; j += 1) {
            const b = activeNodes[j];
            const dx = b.x - a.x;
            const dy = b.y - a.y;
            const distanceSq = Math.max(16, dx * dx + dy * dy);
            const distance = Math.sqrt(distanceSq);
            const minDistance = a.radius + b.radius + 6;
            const repulse = Math.min(1.25, 460 / distanceSq) * alpha;
            const collide = distance < minDistance ? (minDistance - distance) * 0.026 * alpha : 0;
            const force = repulse + collide;
            const fx = (dx / distance) * force;
            const fy = (dy / distance) * force;
            a.vx -= fx;
            a.vy -= fy;
            b.vx += fx;
            b.vy += fy;
          }
        }

        for (const node of activeNodes) {
          const home = cluster[node.kind] ?? cluster.post;
          const targetX = width * home.x;
          const targetY = height * home.y;
          node.vx += (targetX - node.x) * 0.0032 * alpha;
          node.vy += (targetY - node.y) * 0.0032 * alpha;
          node.vx *= 0.86;
          node.vy *= 0.86;
          node.x += node.vx;
          node.y += node.vy;
          node.x = Math.min(width - 32, Math.max(32, node.x));
          node.y = Math.min(height - 32, Math.max(32, node.y));
        }

        alpha *= reduceMotion ? 0.72 : 0.985;
      }

      function draw() {
        if (!ctx) return;
        ctx.clearRect(0, 0, width, height);
        ctx.fillStyle = '#fbfaf7';
        ctx.fillRect(0, 0, width, height);

        for (const link of activeLinks) {
          const highlighted = selected && (link.source === selected.id || link.target === selected.id);
          ctx.beginPath();
          ctx.moveTo(link.sourceNode.x, link.sourceNode.y);
          ctx.lineTo(link.targetNode.x, link.targetNode.y);
          ctx.strokeStyle = highlighted ? 'rgba(217, 71, 71, 0.5)' : 'rgba(31, 36, 69, 0.12)';
          ctx.lineWidth = highlighted ? 1.5 : 0.75;
          ctx.stroke();
        }

        for (const node of nodes) {
          if (!activeNodeIds.has(node.id)) continue;
          const isSelected = selected?.id === node.id;
          const isHovered = hovered?.id === node.id;
          ctx.beginPath();
          ctx.arc(node.x, node.y, node.radius + (isSelected ? 5 : isHovered ? 3 : 0), 0, Math.PI * 2);
          ctx.fillStyle = isSelected ? 'rgba(217, 71, 71, 0.16)' : isHovered ? 'rgba(40, 102, 110, 0.16)' : 'rgba(255, 255, 255, 0.7)';
          ctx.fill();

          ctx.beginPath();
          ctx.arc(node.x, node.y, node.radius, 0, Math.PI * 2);
          ctx.fillStyle = colors[node.kind] ?? colors.post;
          ctx.fill();
          ctx.strokeStyle = '#fff';
          ctx.lineWidth = 2;
          ctx.stroke();

          if (node.featured || isSelected || isHovered || node.kind === 'category') {
            ctx.font = node.featured || isSelected ? '700 13px system-ui' : '700 11px system-ui';
            ctx.textAlign = 'center';
            ctx.fillStyle = '#242120';
            ctx.fillText(node.label.slice(0, 26), node.x, node.y - node.radius - 8);
          }
        }
      }

      function nodeAt(x: number, y: number) {
        let winner = null;
        for (const node of nodes) {
          if (!activeNodeIds.has(node.id)) continue;
          const distance = Math.hypot(node.x - x, node.y - y);
          if (distance <= node.radius + 7) winner = node;
        }
        return winner;
      }

      function pointerPosition(event: PointerEvent) {
        const rect = graphCanvas.getBoundingClientRect();
        return { x: event.clientX - rect.left, y: event.clientY - rect.top };
      }

      graphCanvas.addEventListener('pointermove', (event) => {
        const point = pointerPosition(event);
        hovered = nodeAt(point.x, point.y);
        graphCanvas.style.cursor = hovered ? 'pointer' : 'default';
        if (tooltip) {
          tooltip.hidden = !hovered;
          if (hovered) {
            tooltip.textContent = hovered.label;
            tooltip.style.left = `${point.x + 14}px`;
            tooltip.style.top = `${point.y + 14}px`;
          }
        }
      });

      graphCanvas.addEventListener('pointerleave', () => {
        hovered = null;
        if (tooltip) tooltip.hidden = true;
      });

      graphCanvas.addEventListener('click', (event) => {
        const point = pointerPosition(event);
        const node = nodeAt(point.x, point.y);
        if (node) {
          selected = node;
          updateInspector(node);
          alpha = 0.6;
        }
      });

      buttons.forEach((button) => {
        button.addEventListener('click', () => {
          mode = button.dataset.gridMode ?? 'all';
          buttons.forEach((item) => item.setAttribute('aria-pressed', String(item === button)));
          setActiveGraph();
        });
      });

      search?.addEventListener('input', () => {
        query = search.value.toLowerCase().trim();
        setActiveGraph();
      });

      window.addEventListener('resize', resize);
      updateInspector(selected);
      resize();
      setActiveGraph();

      function frame() {
        tick();
        draw();
        requestAnimationFrame(frame);
      }

      frame();
    }
  }
</script>
