---
import { getCollection } from 'astro:content';
import CategoryShowcase from '@/components/CategoryShowcase.astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { isBrowsablePost, sortPosts } from '@/lib/posts';
import { SITE } from '@/lib/site';

const posts = sortPosts((await getCollection('posts')).filter(isBrowsablePost));
---

<BaseLayout title={SITE.title} description={SITE.description}>
  <h1 class="visually-hidden">PurrfectProse</h1>
  <CategoryShowcase posts={posts} />
</BaseLayout>
